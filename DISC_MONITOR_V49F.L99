  F7A4   0281 2000      OPEN02	CI	R1,' '*256 		;LAST CHARACTER=" "?
  F7A8   1602           	JNE	OPEN03
  F7AA   05CE           	INCT 	R14
  F7AC   10F5           	JMP	OPEN01
