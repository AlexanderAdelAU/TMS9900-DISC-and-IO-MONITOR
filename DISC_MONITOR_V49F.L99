  F834   020E F050      	LI	XR14,PROMPT
  F838   020D 0230      	LI	XR13,WORKSP
  F83C   0380           	RTWP
                        ;
                        ;**************************************************************
                        ;	COMMAND LOAD HEX FILE
                        ;
                        ;	ALGORITHM TAKEN FROM DDJ #22
                        ;
                        ;	R3  HOLDS CHECKSUM
                        ;	R4  HOLDS RECORD LENGTH
                        ;	R5  HOLDS LOAD ADDRESS
                        ;
                        ;***************************************************************
                        ;
  F83E   0202 3A00      HEXLOAD:	LI	R2,':'*256
  F842   2F41           	READ	R1		;SEARCH FOR ':'
  F844   9081           	CB	R1,R2		;COMPARE BYTE FOR :
  F846   16FB           	JNE	HEXLOAD
  F848   2F20 F16A      	WRITE	@DOT		;DEBUG INFO
  F84C   04C3           	CLR 	R3		;CLEAR CHECKSUM
  F84E   06A0 F8E2      	BL	@NEXTBYTE		;GET RECORD LENGTH
  F852   D101           	MOVB	R1,R4
  F854   0984           	SRL	R4,8		;LENGTH IN R4
  F856   1313           	JEQ	INST_EXIT		;WERE DONE
  F858   06A0 F8CC      	BL	@NEXTADDR		;GET LOAD ADDRESS
  F85C   C141           	MOV	R1,R5
  F85E   06A0 F8E2      	BL	@NEXTBYTE		;GET RECORD TYPE
  F862   C104           HL_12	MOV	R4,R4		;IF RL=0 GO TO A13
  F864   1305           	JEQ	HL_13
  F866   06A0 F8E2      	BL	@NEXTBYTE
  F86A   DD41           	MOVB	R1,*R5+		;STORE DATA IN MEMORY
  F86C   0604           	DEC	R4		;REDUCE RECORD LENGTH
  F86E   10F9           	JMP	HL_12
  F870   06A0 F8E2      HL_13	BL	@NEXTBYTE		;GET CHECKSUM BYTE
                        ;	MOVB	R3,R3		;CHECK FOR ZERO
  F874   13E4           	JEQ	HEXLOAD
                        ;
                        ; FALL THROUGH TO ERROR
                        ;
  F876   2F41           HL_14	READ	R1		;READ ANY RUBBISH
  F878   2F20 F16E      	WRITE	@LOADERR		;TELL TERMINAL SYSTEM TO STOP
  F87C   2F41           	READ	R1		;READ ANY RUBBISH
  F87E   0460 F050      INST_EXIT:	B	@PROMPT		;BACK TO TIMON
                        ;
                        ;
                        ;**************************************************************
                        ;	COMMAND LOAD HEX FILE 2
                        ;	SEGMENTED MEMORY PAGES VERSION (V)
                        ;	ADDRESS FORMAT:
                        ;	  A SINGLE BYTE PAGE NUMBER IS NOW INSERTED BEFORE EACH 16 BIT ADDRESS.
                        ;	  IF IT IS ZERO THEN LOAD TO PAGE 0, IF NOT LOAD TO THE PAGE IN THE FIELD
                        ;	  I.E.  00XXXX, 01XXXX ETC
                        ;;
                        ;	ALGORITHM TAKEN FROM DDJ #22
                        ;
                        ;	R3  HOLDS CHECKSUM
                        ;	R4  HOLDS RECORD LENGTH
                        ;	R5  HOLDS LOAD ADDRESS
                        ;
                        ;***************************************************************
                        ;
  F882   0202 3A00      HEXLOAD2:	LI	R2,':'*256
  F886   2F41           	READ	R1		;SEARCH FOR ':'
  F888   9081           	CB	R1,R2		;COMPARE BYTE FOR :
  F88A   16FB           	JNE	HEXLOAD2
  F88C   2F20 F16A      	WRITE	@DOT		;DEBUG INFO
  F890   04C3           	CLR 	R3		;CLEAR CHECKSUM
  F892   06A0 F8E2      	BL	@NEXTBYTE		;GET RECORD LENGTH
  F896   D101           	MOVB	R1,R4
  F898   0984           	SRL	R4,8		;LENGTH IN R4
  F89A   13F1           	JEQ	INST_EXIT		;WERE DONE
  F89C   06A0 F8E2      	BL	@NEXTBYTE		;GET PAGE SETTING BYTE.
  F8A0   D241           	MOVB	R1,R9		;MOVE INTO PAGE/SEGMENT REGISTER
                        ;
                        ;	SHOW AND SET PAGE AND CORRECT FOR CHECKSUM (AB	R1,R3)
                        ;
  F8A2   70C1           	SB	R1,R3
  F8A4   2F20 F16C      	WRITE	@PLUS
  F8A8   2C00           	FAR_REF			;SET PAGE/SEGMENT REGISTER ADDRESS
                        ;
  F8AA   06A0 F8CC      HL_21	BL	@NEXTADDR		;GET LOAD ADDRESS
  F8AE   C141           	MOV	R1,R5
  F8B0   06A0 F8E2      	BL	@NEXTBYTE		;GET RECORD TYPE
  F8B4   C104           HL_22	MOV	R4,R4		;IF RL=0 GO TO A13
  F8B6   1306           	JEQ	HL_23
  F8B8   06A0 F8E2      	BL	@NEXTBYTE
  F8BC   07C0           	LDD			;LONG DISTANCE DESTINATION WRITE
  F8BE   DD41           	MOVB	R1,*R5+		;STORE DATA IN MEMORY
  F8C0   0604           	DEC	R4		;REDUCE RECORD LENGTH
  F8C2   10F8           	JMP	HL_22
  F8C4   06A0 F8E2      HL_23	BL	@NEXTBYTE		;GET CHECKSUM BYTE
                        ;	MOVB	R3,R3		;CHECK FOR ZERO
  F8C8   13DC           	JEQ	HEXLOAD2
  F8CA   10D5           	JMP	HL_14
                        ;
  F8CC   064A           NEXTADDR:	DECT	SP		;SAVE BL RETURN ADDRESS ON STACK
  F8CE   C68B           	MOV	R11,*SP
  F8D0   06A0 F8E2      	BL	@NEXTBYTE
  F8D4   C141           	MOV	R1,R5
  F8D6   06A0 F8E2      	BL	@NEXTBYTE
  F8DA   C2FA           	MOV	*SP+,R11
  F8DC   06C1           	SWPB	R1
  F8DE   E045           	SOC	R5,R1
  F8E0   045B           	RT
                        ;
  F8E2   064A           NEXTBYTE:	DECT	SP		;SAVE BL RETURN ADDRESS
  F8E4   C68B           	MOV	R11,*SP
  F8E6   04C2           	CLR 	R2		;ACCUMULATOR
  F8E8   2F41           	READ	R1
  F8EA   06A0 F902      	BL	@CATOH		;CONVERT ASCII TO HEX
  F8EE   D081           	MOVB	R1,R2
  F8F0   0A42           	SLA	R2,4		;MOVE IT OVER
  F8F2   2F41           	READ	R1		;NEXT ASCII CHAR
  F8F4   06A0 F902      	BL	@CATOH
  F8F8   C2FA           	MOV	*SP+,R11		;POP RETURN ADDRESS
  F8FA   F081           	SOCB	R1,R2		;BYTE NOW IN R1
  F8FC   C042           	MOV	R2,R1
  F8FE   B0C1           	AB	R1,R3		;UPDATE CHECKSUM
  F900   045B           	RT
                        ;
                        ;	ASCII TO HEX CONVERTER
                        ;
  F902   0281 3900      CATOH:	CI	R1,'9'*256
  F906   1202           	JLE	CATOH_1
  F908   0221 0900      	AI	R1,0900H		;ALPHA ADJUST
  F90C   0241 0F00      CATOH_1	ANDI	R1,0F00H
  F910   045B           	RT
                        ;
                        ;---INITIALISE TMS9902 FOR BAUD RATE OF 19200:
                        ;   PROTOCOL SETTINGS
                        ; 	*BAUD RATE
                        ;	*8 BITS/CHARACTER
                        ;	*NO PARITY
                        ;	*2 STOP BITS
                        ;
  0080                  CRUBASE: 	EQU	0080H
                        ;
                        ;CTL02	BYTE	43H		;43H FOR A 3 MHZ CLOCK 4B FOR A 4 MHZ CLOCK
  F912   4B             CTL02	BYTE	4BH		;4BH FOR A 4 MHZ CLOCK
  F913   00             	EVEN
  F914   0002 0009      BD57600	WORD	2,9H 		;BAUD RATE = 57600
  F918   0009 001A      BD19200 	WORD	9,1AH		;BAUD RATE = 19200
  F91C   0013 0034      BD9600	WORD 	19,34H		;BAUD RATE = 9600
                        ;
  F920   0360           INITIAL:	RSET			;RSET
  F922   02E0 EF00      	LWPI	WORKSP2		;USE MONITOR LOCAL WORKSPACE
  F926   020A 0500      	LI	SP,STACKP		;STACK FOR LOCAL MONITOR USE
                        ;
                        ;DISABLE ALL INTERRUPTS WHILE INITALISING
                        ;
  F92A   020C 0080      	LI	R12,CRUBASE
  F92E   1D1F           	SBO	31		;RESET TMS9902
  F930   3220 F912      	LDCR	@CTL02,8
  F934   1E0D           	SBZ	13		;DO NOT SET INTERVAL REGISTER
  F936   04C3           	CLR	R3		;RESET LOOP COUNT
  F938   1F0F           TSTSP	TB	15		;SPACE
  F93A   13FE           	JEQ	TSTSP		;NO JUMP BACK
  F93C   0583           SPLOOP	INC	R3		;TIME THE START BIT
  F93E   1F0F           	TB	15		;FALL OUT ON MARK
  F940   16FD           	JNE	SPLOOP
                        ;
                        ;---TABLE SEARCH FOR BAUD RATES
                        ;	SET AT 19200 or BD57600
                        ;
                        ;	LI	R7,BD19200		;SET POINTER TO TABLE
  F942   0207 F914      	LI	R7,BD57600		;SET POINTER TO TABLE
  F946   05C7           	INCT	R7		;POINT TO THE NEXT WORD THAT HOLDS THE TMS9902 CODES
                        ;
                        ; LOAD THE BAUD RATE VALUES
                        ;
                        
  F948   3317           BDMATCH	LDCR	*R7,12 		;INT RECV/TXMT DATA RATE
  F94A   32D7           	LDCR	*R7,11
  F94C   3607           	STCR	R7,8		;PULL OUT ANY JUNK
  F94E   3607           	STCR	R7,8
                        ;
                        ; CLEAR COMMON MEMORY AND SET SEGMENT
                        ;
  F950   02E0 EF00      	LWPI	WORKSP2		;NEED TO USE WORKSP2 TO BE ABLE TO CLEAR MEMORY
  F954   06A0 F982      	BL	@CLRMEM		;CLEAR MEMORY
  F958   02E0 0230      	LWPI	WORKSP		;STANDARE WORKSPACE FOR MONITOR
  F95C   020A 0500      	LI	SP,STACKP
                        ;	BL	@SETSEGMENT		;MAKE SURE WE ARE IN SEGMENT 0
                        
                        ;
                        ; NOW INITIALISE MONITOR
                        ;
  F960   02A0           	STWP	R0
  F962   C800 EF44      	MOV	R0,@WPSTORE
  F966   06A0 F1EA      	BL	@INIT_VECTORS		;INITIALISE ALL XOP AND INTERRUPT VECTORS
  F96A   04C9           	CLR	R9
  F96C   2C00           	FAR_REF
  F96E   06A0 F2C0      	BL	@IDE_READY		;SEE IF IT IS READY
  F972   C041           	MOV	R1,R1
  F974   1304           	JEQ	INITIAL1
  F976   2FA0 F135      	MESG	@MESS05
  F97A   2FA0 F129      	MESG	@MESS03		;CRLF
  F97E   0460 F048      INITIAL1	B	@BANNER
                        
                        
                        
                        ; CLEAR COMMON MEMORY
                        ;
  F982   04C1           CLRMEM:	CLR	R1
  F984   04F1           CLRMEM0	CLR	*R1+
  F986   0281 0500      	CI	R1,TPA
  F98A   16FC           	JNE	CLRMEM0
  F98C   045B           	RT
                        
                        	;
                        ; CLEAR PAGE ADDESSES AND REVERT TO PAGE 0
                        ;
  F98E   02CF           SETSEGMENT:	STST	R15
  F990   024F FF7F      	ANDI	R15,DISABLE_PSEL	;DISABLE /PSEL MEMORY MAPPER
  F994   008F           	LST	R15
  F996   04C9           	CLR	R9		;CLEAR SEGEMENT AND SELECT PAGE 0
  F998   020C 80C0      	LI	PORT,MEMBASE
  F99C   3089           	LDCR	R9,BYTEWIDE		;GET PAGE VALUE FROM STEP ABOVE;
  F99E   045B           	RT
                        ;
                        ;---Place load vectors into FFFC & FFFE AND BANNER RETURN POINT
                        ;
  FFF8                  	AORG	0FFF8H
  FFF8   0230           	WORD	WORKSP
