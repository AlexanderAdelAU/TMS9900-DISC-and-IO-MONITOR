  F760   04C5           	CLR	R5
                        ;	CLR	R10
  F762   2FA0 F12A      REGIST1	MESG	@MESS03+1		;PRINT SPACE, CR,LF
  F766   0209 5200      REGIST2	LI	R9,'R'*256
  F76A   2F09           	WRITE	R9		;PRINT "R"
  F76C   2F25 F08E      	WRITE	@NUMTAB(R5)		;PRINT REGISTER NO
  F770   2F25 F08F      	WRITE	@NUMTAB+1(R5)	;PRINT REGISTER NO
  F774   2FA0 F131      	MESG	@MESS04
                        	;	R9,'='*256
                        	;WRITE	R9		;PRINT REGISTER CONTENTS
