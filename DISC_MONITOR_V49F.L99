  F7D4   C102           	MOV	R2,R4
  F7D6   0244 FFFE      OUTPUT0 	ANDI	R4,0FFFEH		;MAKE ADDRESS EVEN
  F7DA   C144           	MOV	R4,R5
  F7DC   0245 FFF0      	ANDI	R5,0FFF0H
  F7E0   0225 0080      	AI	R5,80H
  F7E4   2FA0 F12A      OUTPUT1	MESG	@MESS03+1		;PRINT INDENTATION
                        ;	MOV	R4,R2
                        ;	BL	@HEXOUT0		;PRINT ADDRESS
  F7E8   2E84           	WHEX	R4		;PRINT ADDRESS
  F7EA   2FA0 F12E      	MESG	@MESS03+5		;PRINT " "
                        	;MOV	*R4+,R2
                        	;BL	@HEXOUT
  F7EE   2EB4           OUTPUT2 	WHEX	*R4+
  F7F0   2FA0 F12F      	MESG	@MESS03+6		;PRINT " "
  F7F4   8144           	C	R4,R5
  F7F6   1304           	JEQ	OUTPUT3
  F7F8   2520 F0EE      	CZC	@MASK15,R4
  F7FC   13F3           	JEQ	OUTPUT1
  F7FE   10F7           	JMP	OUTPUT2
  F800   2F41           OUTPUT3	READ	R1		;GET CHARACTER
  F802   0281 2000      	CI	R1,' '*256
  F806   16D8           	JNE	MON00A
  F808   0225 0080      	AI	R5,80H		;AN EXTRA 4 LINES
  F80C   10EB           	JMP	OUTPUT1
                        ;
                        ; INSTRUCTION W
                        ;
