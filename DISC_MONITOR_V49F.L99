  F7C2   2FA0 F12F      	MESG	@MESS03+6		;PRINT "  "
  F7C6   2E9E           	WHEX	*R14		;PRINT CONTENTS OF ADDRESS
                        	;BL	@HEXOUT
  F7C8   2FA0 F12F      	MESG	@MESS03+6		;PRINT "  "
  F7CC   045B           	RT			;RETURN FROM BL
