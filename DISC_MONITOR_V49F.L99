  F828   0A74           	SLA	XR4,7		;SHIFT INTO MSB
  F82A   020C 80C0      	LI	PORT,MEMBASE
  F82E   3084           	LDCR	XR4,BYTEWIDE		;GET PAGE VALUE FROM STEP ABOVE
