  F770   0208 0010      	LI	R8,16
  F774   2FA0 F044       	MESG	@CRLF		;PRINT INDENTATION
  F778   2FA0 EF20       	MESG	@DEBUG_NAME		;PRINT THE NAME OF THE MODULE
  F77C   2FA0 F803       	MESG	@SP_REG
  F780   C2AD 0014       	MOV	@2*SP(R13),R10	;GET STACK POINTER
  F784   2E9A            	WHEX	*R10		;PRINT CONTENTS
