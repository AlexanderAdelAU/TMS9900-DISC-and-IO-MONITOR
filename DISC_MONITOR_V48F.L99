  F79E   2F0A           	WRITE	R10
  F7A0   020A 3000      LIST_REGA:	LI	R10,30H*256		;PRINT 0
  F7A4   0A1B           	SLA	R11,1
  F7A6   1802           	JOC	LIST_REGB
  F7A8   2F0A           	WRITE	R10
  F7AA   1003           	JMP	LIST_REGC
  F7AC   022A 0100      LIST_REGB:	AI	R10,1*256		;PRINT 1
  F7B0   2F0A           	WRITE	R10
  F7B2   0608           LIST_REGC:	DEC	R8
  F7B4   16F5           	JNE	LIST_REGA
  F7B6   04CA           	CLR	R10
  F7B8   2FA0 F044      LIST_REG1:	MESG	@CRLF		;PRINT CR,LF
  F7BC   0208 5200      LIST_REG2:	LI	R8,'R'*256
  F7C0   2F08           	WRITE	R8		;PRINT "R"
  F7C2   2F2A F08E      	WRITE	@NUMTAB(R10)	;PRINT REGISTER NO
  F7C6   2F2A F08F      	WRITE	@NUMTAB+1(R10)	;PRINT REGISTER NO
  F7CA   0208 3D00      	LI	R8,'='*256
  F7CE   2F08           	WRITE	R8
  F7D0   2EB9           	WHEX	*R9+		;PRINT REGISTER CONTENTS
  F7D2   05CA           	INCT	R10
  F7D4   028A 0020      	CI	R10,20H
  F7D8   1307           	JEQ	LIST_EXIT
  F7DA   0208 2000      	LI	R8,' '*256		;PRINT A SPACE
  F7DE   2F08           	WRITE	R8
  F7E0   26A0 F0EE      	CZC	@MASK15,R10
  F7E4   13E9           	JEQ	LIST_REG1
  F7E6   10EA           	JMP	LIST_REG2
  F7E8   2FA0 F044      LIST_EXIT:	MESG	@CRLF		;PRINT INDENTATION
  F7EC   0380           	RTWP
                        
  F7EE   2057 5020      WP_REG:	TEXT	' WP = '
  F7F2   3D20           
  F7F4   00             	BYTE	0
  F7F5   2053 5420      ST_REG:	TEXT	' ST = '
  F7F9   3D20           
  F7FB   00             	BYTE	0
