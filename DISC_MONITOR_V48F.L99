  F78A   2EB9           	WHEX	*R9+
  F78C   2FA0 F7EE      	MESG	@WP_REG		;WORKSPACE POINTER
  F790   2EB9           	WHEX	*R9+
  F792   2FA0 F7F5      	MESG	@ST_REG		;PRINT " ST="
